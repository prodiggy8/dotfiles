# by discomanfulanito,
# for everyone — as code should be

# Sprites are drawn from here
POKEMON_LIST=(
  articuno
  charizard
  lugia
  lapras
  "ninetales --alolan"
  snorlax
  marowak
  onix
  arceus
  dragonair
  lucario
  chandelure
  "mewtwo --mega-y"
)

# Change with your fetcher
FETCHER=(fastfetch --logo none -c config-compact)

FETCHER_HEIGHT=$(${FETCHER[@]} | wc -l)

# Extra settings
EXTRA_PADDING_H=2

# Gets a sprite via pokeget
index=$(( (RANDOM % ${#POKEMON_LIST[@]}) + 1 ))
sprite=$(eval "pokeget ${POKEMON_LIST[$index]} --hide-name")

# Gets sprite's height
height=$(echo "$sprite" | wc -l)

# Pad for vertical centering
pad_top=$((($FETCHER_HEIGHT - $height) / 2))
pad_top=$((pad_top + EXTRA_PADDING_H))

# Just for safety
(( pad_top < 0 )) && pad_top=0

# Gets sprite's sprite_width
# strip ANSI color codes with sed to get the true printed width
sprite_width=$(
  printf '%s\n' "$sprite" \
  | sed 's/\x1b\[[0-9;]*m//g' \
  | awk '{ if (length > max) max = length } END { print max }'
)


# this may not work for your fetcher, check them all
echo "$sprite" | "${FETCHER[@]}" --file-raw - \
    --logo-padding-top $pad_top \
    --logo-padding-left 10 \
    --logo-padding-right 5
